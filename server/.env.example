# ── call-bot backend configuration ──────────────────────────────────────────
# Copy to .env and fill in. Never commit the real .env.

# HTTP API
PORT=4000
# Comma-separated origins allowed to call the API / open the websocket.
CORS_ORIGIN=http://localhost:5173
# Long random string. Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=12h

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=callbot
DB_PASSWORD=change-me
DB_NAME=callbot
DB_CONNECTION_LIMIT=15

# ── Asterisk ARI ─────────────────────────────────────────────────────────────
# Matches asterisk/ari.conf.sample. ARI listens on Asterisk's HTTP server.
ARI_URL=http://127.0.0.1:8088
ARI_USERNAME=callbot
ARI_PASSWORD=change-me
# Stasis application name (must match the one referenced in extensions.conf).
ARI_APP=callbot

# ── Outbound dialing ─────────────────────────────────────────────────────────
# How channels are created. {number} is replaced with the contact's phone.
# For a pjsip trunk named "trunk" (see pjsip.conf.sample): PJSIP/{number}@trunk
DIAL_ENDPOINT_TEMPLATE=PJSIP/{number}@trunk
# Optional digits prepended to every number (e.g. national/intl prefix). Blank = none.
DIAL_PREFIX=
# Default country calling code used when normalizing local numbers (digits only, no +).
# Leave blank to dial numbers exactly as provided (after stripping non-digits).
DEFAULT_COUNTRY_CODE=
# Seconds to wait for the callee to answer before marking NO ANSWER.
ORIGINATE_TIMEOUT=30
# Dialplan context that runs AMD() then Stasis() (see asterisk/extensions.conf.sample).
# Used only for campaigns with answering-machine detection enabled.
DIAL_AMD_CONTEXT=callbot-amd

# ── Trunk capacity (the only dialing setting to tune) ────────────────────────
# Campaigns auto-pace based on contact-list size, but never exceed these limits.
# Set them to what your SIP trunk actually allows. A small/demo trunk = small
# numbers (e.g. MAX_CONCURRENT_CALLS=2, MAX_CPS=1); a large carrier trunk can be
# hundreds (e.g. MAX_CONCURRENT_CALLS=240, MAX_CPS=50).
MAX_CONCURRENT_CALLS=10
MAX_CPS=3
# Auto-pacing sizing. AVG_CALL_SECONDS ~ how long a call holds a line (ring +
# message). TARGET_MINUTES = the finish-time window the app aims for; it raises
# cps automatically for big lists (never above MAX_CPS) so they don't crawl.
AVG_CALL_SECONDS=20
TARGET_MINUTES=30

# ── Storage ──────────────────────────────────────────────────────────────────
# Where converted audio is written. MUST be Asterisk's sounds dir (<astdatadir>/sounds)
# so `sound:callbot/<file>` resolves. Check with: grep astdatadir /etc/asterisk/asterisk.conf
#   Debian:        /usr/share/asterisk/sounds/callbot
#   CentOS/source: /var/lib/asterisk/sounds/callbot
AUDIO_DIR=/usr/share/asterisk/sounds/callbot
# Temp dir for uploads before processing.
UPLOAD_TMP_DIR=./uploads/tmp
# Path to ffmpeg binary (used to convert uploaded audio).
FFMPEG_PATH=ffmpeg
